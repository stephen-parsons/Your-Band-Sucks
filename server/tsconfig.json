{
  "compilerOptions": {
    "target": "ES6", // Use ECMAScript 2015 (ES6)
    "module": "commonjs", // Compile to CommonJS modules
    "outDir": "./dist", // Output directory for compiled JavaScript files
    "rootDir": ".", // Root directory of input files
    "strict": true, // Enable all strict type-checking options
    "esModuleInterop": true, // Enables compatibility with ES modules
    "skipLibCheck": true, // Skip type checking for declaration files
    "forceConsistentCasingInFileNames": true // Ensure file names are case-insensitive on case-sensitive file systems
  },
  "include": ["./**/*"], // Include all TypeScript files in the ./server directory and subdirectories
  "exclude": ["node_modules"] // Exclude node_modules from compilation
}
