// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum LikeType {
  LIKE
  DISLIKE
}

model User {  
  id        Int       @id @default(autoincrement())
  name      String  
  email     String    @unique
  password  String  
  songs     Song[]
  likes     LikeDislike[]
  createdAt DateTime @default(now())
  updatedAt DateTime?  @updatedAt
}

model Song {    
  id        Int       @id @default(autoincrement())     
  userId    Int       // Foreign key connecting Song to User
  user      User      @relation(fields: [userId], references: [id])   
  title     String    
  description     String
  key       String @default("")    //object key in s3 bucket
  likeCount Int @default(0)
  likes LikeDislike[]
  createdAt DateTime @default(now())
  updatedAt DateTime?  @updatedAt
  tags Tag[]
}

model LikeDislike {    
  id        Int       @id @default(autoincrement())
  type      LikeType  // Enum: LIKE or DISLIKE     
  userId    Int       // Foreign key connecting Like to User
  user      User      @relation(fields: [userId], references: [id])   
  songId    Int       // Foreign key connecting Like to Song
  song      Song      @relation(fields: [songId], references: [id])
  createdAt DateTime  @default(now())
  updatedAt DateTime?  @updatedAt
  // Constraints: A user can only like/dislike a post once
  @@unique([userId, songId])
}

model Tag {    
  id        Int       @id @default(autoincrement())     
  description String  @unique 
  songs     Song[]    
  createdAt DateTime  @default(now())
  updatedAt DateTime?  @updatedAt
}
