// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {  
  id        Int       @id @default(autoincrement())
  name      String  
  email     String    @unique
  password  String  
  songs     Song[]
  likes     Like[]
  createdAt DateTime @default(now())
}

model Song {    
  id        Int       @id @default(autoincrement())     
  userId    Int       // Foreign key connecting Song to User
  user      User      @relation(fields: [userId], references: [id])   
  title     String    
  description     String
  likeCount Int @default(0)
  likes Like[]
  createdAt DateTime @default(now())
  tags Tag[]
}

model Like {    
  id        Int       @id @default(autoincrement())     
  userId    Int       // Foreign key connecting Like to User
  user      User      @relation(fields: [userId], references: [id])   
  songId    Int       // Foreign key connecting Like to Song
  song      Song      @relation(fields: [songId], references: [id])
  createdAt DateTime @default(now())
}

model Tag {    
  id        Int       @id @default(autoincrement())     
  description String   // Field for tag description
  songs     Song[]    // New field for Songs
}
